# =====================================================
# PP Framework - ตัวอย่างค่า Environment
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามต้องการ
# =====================================================

# --- เซิร์ฟเวอร์ ---
# พอร์ตที่ใช้รันเว็บ (ค่าเริ่มต้น 3000)
PORT=3000

# สภาพแวดล้อม: development | production
NODE_ENV=development

# โฮสต์ที่อนุญาตให้เข้าถึง (คั่นด้วยคอมม่า หรือเว้นว่างไว้ = ทุกโฮสต์)
ALLOWED_HOSTS=

# --- ฐานข้อมูล SQLite ---
# ตำแหน่งไฟล์ฐานข้อมูล (บน Coolify ใช้ /app/data/database.sqlite)
DB_PATH=./data/database.sqlite

# --- Session / Security ---
# รหัสลับสำหรับ session (เปลี่ยนเป็นค่าสุ่มยาวๆ ในโปรดักชัน)
SESSION_SECRET=pp-framework-change-this-secret-in-production

# อายุของ session (หน่วยมิลลิวินาที) - ค่าเริ่มต้น 1 วัน
SESSION_MAX_AGE=86400000

# ชื่อผู้ใช้และรหัสผ่านของผู้ดูแลระบบเริ่มต้น
# (ใช้ตอน seed ครั้งแรกเท่านั้น)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@pp-framework.local
ADMIN_FULLNAME=ผู้ดูแลระบบ

# --- Logging ---
# ระดับ log: error | warn | info | debug
LOG_LEVEL=info
# โฟลเดอร์เก็บ log
LOG_DIR=./logs